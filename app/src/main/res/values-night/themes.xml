<resources>
    <!-- Base application theme. -->
    <style name="Theme.Aiscanner" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/brand_primary_container</item>
        <item name="colorSecondaryVariant">@color/brand_primary_container</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="android:colorBackground">@color/page_background</item>
        <item name="colorSurface">@color/surface_card</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/brand_primary</item>
        <item name="android:navigationBarColor">@color/page_background</item>
        <!-- Customize your theme here. -->
    </style>
</resources>